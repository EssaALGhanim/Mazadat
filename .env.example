# Copy this file to .env and update with your values
# This file is used by docker-compose for environment variables

# MySQL Configuration
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=mazadat
MYSQL_USER=mazadat_user
MYSQL_PASSWORD=mazadat_password

# Spring Boot Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/mazadat
SPRING_DATASOURCE_USERNAME=mazadat_user
SPRING_DATASOURCE_PASSWORD=mazadat_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SERVER_PORT=8080

# File Upload Configuration
MAZADAT_UPLOAD_DIR=/app/uploads

# Frontend Configuration
VITE_API_URL=http://localhost:8080

# Additional Spring Boot Settings
SPRING_PROFILES_ACTIVE=docker
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOGGING_LEVEL_ORG_EXAMPLE_MAZADAT=DEBUG

# Optional: Timezone
TZ=Asia/Riyadh

